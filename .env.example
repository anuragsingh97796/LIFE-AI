# Supabase Configuration
# Rename this file to .env and fill in your Supabase project credentials.
# These will be automatically picked up by Expo CLI and made available in the app.

EXPO_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
